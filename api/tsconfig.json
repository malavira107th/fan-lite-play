{
  "extends": "../tsconfig.json",
  "include": ["server.ts", "../server/**/*", "../shared/**/*", "../drizzle/**/*"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "../dist/api",
    "skipLibCheck": true,
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "strict": false
  }
}
